{
  "name": "obsidian-checklist",
  "version": "0.2.5",
  "description": "Checklist views plugin for Obsidian - create Bases-like checklist views with checkboxes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "test:watch": "jest --watch",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "checklist",
    "plugin"
  ],
  "license": "AGPL-3.0",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.20.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "obsidian": "latest",
    "ts-jest": "^29.1.2",
    "tslib": "2.6.2",
    "typescript": "5.3.3"
  }
}
